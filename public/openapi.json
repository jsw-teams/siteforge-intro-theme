{
  "openapi": "3.1.0",
  "info": {
    "title": "JS.Gripe Public Resources",
    "version": "1.0.0",
    "description": "Public, read-only resources for discovering JS.Gripe pages and Markdown mirrors."
  },
  "servers": [
    {
      "url": "https://js.gripe"
    }
  ],
  "paths": {
    "/llms.txt": {
      "get": {
        "operationId": "getLlmsTxt",
        "summary": "Get a concise public content guide.",
        "responses": {
          "200": {
            "description": "Plain text site guide.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/status.json": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get static publication status for the public site.",
        "responses": {
          "200": {
            "description": "Status response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "service": { "type": "string" },
                    "site": { "type": "string" },
                    "public": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
