---
import { footerItems } from '../data/nav';
import { messages } from '../i18n/messages';
import type { Lang, PageKey } from '../i18n/config';
import { getPagePath, withBase } from '../lib/i18n';
import { getFooterCopyright } from '../lib/theme-config';
import themeConfig from '../../themes/jishu-pixel/theme.yml?raw';

type Props = {
  lang: Lang;
  page: PageKey;
};

const { lang, page } = Astro.props;
const t = messages[lang];
const copyright = getFooterCopyright(themeConfig, lang, new Date().getUTCFullYear());
---
<footer class="site-footer">
  {copyright && <p class="footer-brand">{copyright}</p>}
  <nav class="footer-links" aria-label={t.pages.privacy.heading}>
    {footerItems.map((item) => (
      <a href={getPagePath(lang, item)} aria-current={page === item ? 'page' : undefined}>
        {t.pages[item].heading}
      </a>
    ))}
    <a href={withBase('/sitemap.xml')}>{t.sitemap}</a>
  </nav>
</footer>
