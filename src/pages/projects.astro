---
import ContentPage from '../components/ContentPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLang, type PageKey } from '../i18n/config';
import { messages } from '../i18n/messages';

const lang = defaultLang;
const page: PageKey = 'projects';
const t = messages[lang];
---
<BaseLayout lang={lang} page={page} seo={{ robots: 'noindex, follow' }}>
  <ContentPage lang={lang} page={page} mascot="/assets/brand/mascot-sheet.png" mascotAlt={t.projects.mascotAlt} />
</BaseLayout>
