---
import ContentPage from '../../components/ContentPage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { prefixedLanguages, type PageKey } from '../../i18n/config';
import { messages } from '../../i18n/messages';
import { getLang } from '../../lib/i18n';

export function getStaticPaths() {
  return prefixedLanguages.map((lang) => ({ params: { lang } }));
}

const lang = getLang(Astro.params.lang);
const page: PageKey = 'privacy';
const t = messages[lang];
---
<BaseLayout lang={lang} page={page}>
  <ContentPage lang={lang} page={page} mascot="/assets/brand/mascot-sheet.png" mascotAlt={t.home.heroAlt} />
</BaseLayout>
