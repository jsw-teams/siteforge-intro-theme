---
import MascotCard from '../../components/MascotCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { prefixedLanguages, type PageKey } from '../../i18n/config';
import { messages } from '../../i18n/messages';
import { getLang, getPagePath } from '../../lib/i18n';

export function getStaticPaths() {
  return prefixedLanguages.map((lang) => ({ params: { lang } }));
}

const lang = getLang(Astro.params.lang);
const page: PageKey = 'home';
const t = messages[lang];
const entries = ['projects', 'writing', 'friends', 'contact'] as const;
---
<BaseLayout lang={lang} page={page}>
  <section class="hero" aria-labelledby="page-title">
    <div class="hero-copy">
      <p class="eyebrow">{t.pages.home.eyebrow}</p>
      <h1 id="page-title">{t.pages.home.heading}</h1>
      <p class="lead">{t.home.lead}</p>
      <div class="entry-grid" aria-label={t.navLabel}>
        {entries.map((entry) => (
          <a class="entry-card" href={getPagePath(lang, entry)}>
            <h2>{t.cards[entry]}</h2>
            <p>{t.home.entries[entry]}</p>
          </a>
        ))}
      </div>
    </div>
    <MascotCard image="/assets/brand/mascot-home.png" alt={t.home.heroAlt} />
  </section>
</BaseLayout>
