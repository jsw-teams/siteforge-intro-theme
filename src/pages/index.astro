---
import MascotCard from '../components/MascotCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLang, type PageKey } from '../i18n/config';
import { messages } from '../i18n/messages';
import { getPagePath } from '../lib/i18n';
import { getThemeNavigation } from '../lib/theme-config';
import themeConfigRaw from '../../themes/intro/theme.yml?raw';
import '../../themes/intro/styles/home.css';

const lang = defaultLang;
const page: PageKey = 'home';
const t = messages[lang];
const navigation = getThemeNavigation(themeConfigRaw);
---
<BaseLayout lang={lang} page={page}>
  <section class="hero" aria-labelledby="page-title">
    <div class="hero-copy">
      <p class="eyebrow">{t.pages.home.eyebrow}</p>
      <h1 id="page-title">{t.pages.home.heading}</h1>
      <p class="lead">{t.home.lead}</p>
      <div class="entry-grid" aria-label={t.navLabel}>
        {navigation.primary.map((entry) => (
          <a class="entry-card" data-tone={entry.tone} href={getPagePath(lang, entry.key)}>
            <span class="entry-kicker">{entry.key}</span>
            <h2>{t.cards[entry.key as keyof typeof t.cards] ?? t.pages[entry.key].heading}</h2>
            <p>{t.home.entries[entry.key as keyof typeof t.home.entries]}</p>
          </a>
        ))}
      </div>
      <nav class="quick-links" aria-label={t.navLabel}>
        {navigation.secondary.map((entry) => (
          <a href={getPagePath(lang, entry.key)}>{t.pages[entry.key].heading}</a>
        ))}
      </nav>
    </div>
    <MascotCard alt={t.home.heroAlt} />
  </section>
</BaseLayout>
