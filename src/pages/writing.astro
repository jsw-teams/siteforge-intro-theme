---
import MascotCard from '../components/MascotCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLang, type PageKey } from '../i18n/config';
import { messages } from '../i18n/messages';
import { getBlogUrl } from '../lib/blog';
import { withBase } from '../lib/i18n';

const lang = defaultLang;
const page: PageKey = 'writing';
const t = messages[lang];
const blogUrl = getBlogUrl(lang);
---
<BaseLayout lang={lang} page={page}>
  <section class="page-heading" aria-labelledby="page-title">
    <h1 id="page-title">{t.pages.writing.heading}</h1>
    <p class="lead">{t.writing.lead}</p>
  </section>
  <div class="content-grid writing-layout">
    <section class="article-list" aria-labelledby="recent-posts">
      <div class="section-heading">
        <div>
          <h2 id="recent-posts">{t.writing.recentHeading}</h2>
        </div>
        <a class="button-link" href={blogUrl} rel="noopener noreferrer">{t.writing.blogLink}</a>
      </div>
      <div
        class="dynamic-posts"
        data-recent-posts
        data-endpoint={withBase('/recent-posts.json')}
        data-lang={lang}
        data-empty-title={t.writing.emptyTitle}
        data-empty-text={t.writing.emptyText}
        data-published={t.writing.published}
        data-read-more={t.writing.readMore}
      >
        <div class="empty-state">
          <h2>{t.writing.loadingTitle}</h2>
          <p>{t.writing.loadingText}</p>
        </div>
      </div>
    </section>
    <MascotCard image="/assets/brand/mascot-sheet.png" compact alt={t.writing.mascotAlt} />
  </div>
  <script is:inline src={withBase('/assets/recent-posts.js')} defer></script>
</BaseLayout>
