---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';
import type { Lang, PageKey } from '../i18n/config';
import { messages } from '../i18n/messages';
import type { SeoOverrides } from '../lib/seo';
import { withBase } from '../lib/i18n';
import '../../themes/intro/style.css';
import '../styles/global.css';
import consentScriptUrl from '../../themes/intro/scripts/consent.js?url';
import consentStyleUrl from '../../themes/intro/styles/consent.css?url';
import themeConfigRaw from '../../themes/intro/theme.yml?raw';
import webMcpScriptRaw from '../../themes/intro/scripts/web-mcp.js?raw';
import { getThemeAssetUrls, getThemeBodyEndScripts, getThemeBrowserConfig, getThemeHeadScripts } from '../lib/theme-config';

type Props = {
  lang: Lang;
  page: PageKey;
  seo?: SeoOverrides;
};

const { lang, page, seo } = Astro.props;
const t = messages[lang];
const themeAssetUrls = getThemeAssetUrls(themeConfigRaw, withBase, { 'styles/consent.css': consentStyleUrl });
const themeConfig = getThemeBrowserConfig(themeConfigRaw, {
  basePath: import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, ''),
  consentStyleUrl,
  assetUrls: themeAssetUrls
});
const bodyEndScripts = getThemeBodyEndScripts(themeConfigRaw, withBase, themeAssetUrls);
const headScripts = getThemeHeadScripts(themeConfigRaw, withBase, themeAssetUrls);
const getInlineHeadScript = (src: string) =>
  src.endsWith('/assets/theme/intro/scripts/web-mcp.js') ? webMcpScriptRaw : '';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <Seo lang={lang} page={page} seo={seo} />
    {headScripts.map((script) =>
      getInlineHeadScript(script.src) ? (
        <script is:inline set:html={getInlineHeadScript(script.src)}></script>
      ) : (
        <script
          is:inline
          src={script.src}
          defer={script.defer}
          async={script.async}
          {...script.attrs}
        ></script>
      )
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{t.skip}</a>
    <div class="page-shell">
      <Header lang={lang} page={page} />
      <main id="main" tabindex="-1">
        <slot />
      </main>
      <Footer lang={lang} page={page} />
    </div>
    <script is:inline set:html={`window.JSGripeConfig = ${JSON.stringify(themeConfig)};`} />
    <script is:inline src={consentScriptUrl} defer></script>
    {bodyEndScripts.map((script) => (
      <script
        is:inline
        type={script.consent ? 'text/plain' : undefined}
        src={script.consent ? undefined : script.src}
        data-consent-category={script.consent}
        data-consent-src={script.consent ? script.src : undefined}
        defer={script.defer}
        async={script.async}
        {...script.attrs}
      ></script>
    ))}
  </body>
</html>
